generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── User (Auth) ──────────────────────────────────────────────
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         UserRole      @default(CASHIER)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  orders       Order[]
  terminals    PosTerminal[]

  @@map("users")
}

// ─── Branch ───────────────────────────────────────────────────
model Branch {
  id          String       @id @default(uuid())
  name        String       @unique
  address     String?
  phone       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  categories  Category[]
  floors      Floor[]
  products    Product[]
  terminals   PosTerminal[]
  orders      Order[]

  @@map("branches")
}

// ─── Category ─────────────────────────────────────────────────
model Category {
  id        String    @id @default(uuid())
  branchId  String?   @map("branch_id")
  name      String
  imageUrl  String?   @map("image_url")

  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([branchId, name])
  @@map("categories")
}

// ─── Product ──────────────────────────────────────────────────
model Product {
  id          String      @id @default(uuid())
  branchId    String?     @map("branch_id")
  categoryId  String?     @map("category_id")
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  taxRate     Decimal     @default(0) @map("tax_rate") @db.Decimal(5, 2)
  barcode     String?
  imageUrl    String?     @map("image_url")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  branch      Branch?     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]

  @@map("products")
}

// ─── Floor ────────────────────────────────────────────────────
model Floor {
  id        String  @id @default(uuid())
  branchId  String? @map("branch_id")
  name      String

  branch    Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables    Table[]

  @@map("floors")
}

// ─── Table ────────────────────────────────────────────────────
model Table {
  id          String      @id @default(uuid())
  floorId     String?     @map("floor_id")
  tableNumber Int         @map("table_number")
  seats       Int         @default(4)
  status      TableStatus @default(FREE)

  floor       Floor?      @relation(fields: [floorId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@map("tables")
}

// ─── POS Terminal ─────────────────────────────────────────────
model PosTerminal {
  id           String    @id @default(uuid())
  branchId     String?   @map("branch_id")
  userId       String?   @map("user_id")
  name         String    @map("terminal_name")
  createdAt    DateTime  @default(now()) @map("created_at")

  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id])
  sessions        PosSession[]
  paymentSettings PaymentSettings?

  @@map("pos_terminals")
}

// ─── POS Session ──────────────────────────────────────────────
model PosSession {
  id           String      @id @default(uuid())
  terminalId   String?     @map("terminal_id")
  openedAt     DateTime    @default(now()) @map("opened_at")
  closedAt     DateTime?   @map("closed_at")
  openingCash  Decimal     @default(0) @map("opening_cash") @db.Decimal(12, 2)
  closingCash  Decimal?    @map("closing_cash") @db.Decimal(12, 2)
  totalSales   Decimal     @default(0) @map("total_sales") @db.Decimal(12, 2)

  terminal     PosTerminal? @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@map("pos_sessions")
}

// ─── Customer ─────────────────────────────────────────────────
model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String?  @unique
  phone      String?  @unique
  address    String?
  totalSpent Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  orders     Order[]

  @@map("customers")
}

// ─── Order ────────────────────────────────────────────────────
model Order {
  id          String      @id @default(uuid())
  branchId    String?     @map("branch_id")
  sessionId   String?     @map("session_id")
  tableId     String?     @map("table_id")
  customerId  String?     @map("customer_id")
  cashierId   String?     @map("cashier_id")
  orderType   OrderType   @map("order_type")
  status      OrderStatus @default(DRAFT)
  notes       String?
  totalAmount Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  taxAmount   Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  branch      Branch?     @relation(fields: [branchId], references: [id])
  session     PosSession? @relation(fields: [sessionId], references: [id])
  table       Table?      @relation(fields: [tableId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  cashier     User?       @relation(fields: [cashierId], references: [id])

  orderItems  OrderItem[]
  payments    Payment[]
  receipts    Receipt[]

  @@map("orders")
}

// ─── Order Item ───────────────────────────────────────────────
model OrderItem {
  id           String   @id @default(uuid())
  orderId      String?  @map("order_id")
  productId    String?  @map("product_id")
  productName  String   @map("product_name")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxRate      Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  notes        String?
  kitchenSent  Boolean  @default(false) @map("kitchen_sent")

  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Payment ──────────────────────────────────────────────────
model Payment {
  id            String        @id @default(uuid())
  orderId       String?       @map("order_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(PENDING)
  reference     String?
  upiId         String?       @map("upi_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  order         Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Receipt ──────────────────────────────────────────────────
model Receipt {
  id            String   @id @default(uuid())
  orderId       String?  @map("order_id")
  receiptNumber String   @unique @map("receipt_number")
  generatedAt   DateTime @default(now()) @map("generated_at")

  order         Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

// ─── Payment Settings ─────────────────────────────────────────
model PaymentSettings {
  id           String   @id @default(uuid())
  terminalId   String   @unique @map("terminal_id")
  enableCash   Boolean  @default(true) @map("enable_cash")
  enableCard   Boolean  @default(false) @map("enable_card")
  enableUpi    Boolean  @default(false) @map("enable_upi")
  upiId        String?  @map("upi_id")
  upiName      String?  @map("upi_name")
  merchantCode String?  @map("merchant_code")
  updatedAt    DateTime @updatedAt @map("updated_at")

  terminal     PosTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@map("payment_settings")
}

// ─── Enums (unchanged) ────────────────────────────────────────
enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  DRAFT
  CREATED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  SPLIT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}